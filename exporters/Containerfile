FROM registry.access.redhat.com/ubi9/python-311:1

ARG WORK_DIR=/app/pelorus

ENV APP_FILE=deploytime/app.py
ENV PYTHONPATH=$WORK_DIR

USER root

RUN (dnf -y install skopeo && dnf clean all) || echo "skopeo not available, container image commit detection disabled" && \
    mkdir -p $WORK_DIR && \
    chown -R 1001:0 $WORK_DIR

USER 1001

WORKDIR $WORK_DIR

COPY --chown=1001:0 requirements.txt $WORK_DIR/requirements.txt

RUN pip install --no-cache-dir -r requirements.txt

COPY --chown=1001:0 ./ $WORK_DIR

CMD python ${APP_FILE}
